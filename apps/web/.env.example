# Local dev defaults to /api (Vite proxy). By default the proxy targets localhost:3000.
# To test against a deployed API while keeping same-origin cookies, use .env.local:
# VITE_DEV_API_PROXY_TARGET="https://split-the-bill-api-1099488675893.northamerica-northeast2.run.app"
# Also set COOKIE_SECURE=false on the Cloud Run API while testing over http://localhost.
#
# For production builds only (npm run build):
# VITE_API_URL="https://split-the-bill-api-1099488675893.northamerica-northeast2.run.app"
