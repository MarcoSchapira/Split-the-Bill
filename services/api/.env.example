DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="dev_secret_change_later"
JWT_EXPIRES_IN="7d"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"
WEB_ORIGIN="http://localhost:5173"
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"
# Production with a separate API host (no /api reverse proxy) needs cross-site cookies:
# WEB_ORIGIN="https://split-the-bill.net"
# COOKIE_SECURE="true"
# COOKIE_SAME_SITE="none"
# TRUST_PROXY="true"
TRUST_PROXY="false"
# Set to true only for local CLI/testing clients that need Bearer tokens in auth JSON responses.
# ALLOW_AUTH_TOKEN_RESPONSE="true"
#
# Mobile apps (Flutter) use header X-EquiSplit-Client: mobile to receive accessToken and
# refreshToken in login/register/refresh JSON responses. Bearer auth skips CSRF checks.
PORT=3000
NODE_ENV="development"
RESEND_API_KEY=""
EMAIL_FROM="EquiSplit <onboarding@yourdomain.com>"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"
