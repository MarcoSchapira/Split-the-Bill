generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String?
  passwordHash   String?  @map("password_hash")
  authProvider   String   @default("local") @map("auth_provider")
  providerUserId String?   @map("provider_user_id")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sentFriendInvitations     FriendInvitation[]  @relation("FriendInvitationSender")
  receivedFriendInvitations FriendInvitation[]  @relation("FriendInvitationRecipient")
  friendshipsA              Friendship[]        @relation("FriendshipUserA")
  friendshipsB              Friendship[]        @relation("FriendshipUserB")
  createdBills              Bill[]              @relation("BillCreator")
  paidBills                 Bill[]              @relation("BillPayer")
  billShares                BillShare[]
  lineItemAssignments       BillLineItemAssignment[]
  activityEvents            ActivityEvent[]     @relation("ActivityActor")
  activityRecipients        ActivityRecipient[]
  sessions                  Session[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenHash])
  @@map("sessions")
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  codeHash  String   @map("code_hash")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("email_verifications")
}

model Friendship {
  id        String   @id @default(uuid())
  userAId   String   @map("user_a_id")
  userBId   String   @map("user_b_id")
  createdAt DateTime @default(now()) @map("created_at")

  userA User   @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User   @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("friendships")
}

model FriendInvitation {
  id             String    @id @default(uuid())
  senderId       String    @map("sender_id")
  recipientId    String?   @map("recipient_id")
  recipientEmail String?   @map("recipient_email")
  status         String    @default("pending")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  respondedAt    DateTime? @map("responded_at")

  sender     User            @relation("FriendInvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient  User?           @relation("FriendInvitationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  activities ActivityEvent[]

  @@index([senderId])
  @@index([recipientId])
  @@index([recipientEmail])
  @@index([status])
  @@map("friend_invitations")
}

model Bill {
  id            String    @id @default(uuid())
  description   String
  source        String    @default("manual")
  isOneMainTotal      Boolean   @default(true) @map("is_one_main_total")
  isSplitWithFriends  Boolean   @default(false) @map("is_split_with_friends")
  isSplitByFinalAmounts Boolean @default(true) @map("is_split_by_final_amounts")
  incurredAt    DateTime  @map("incurred_at")
  totalCents    Int       @map("total_cents")
  storeName     String?   @map("store_name")
  storeAddress  String?   @map("store_address")
  receiptNumber String?   @map("receipt_number")
  receiptDate   String?   @map("receipt_date")
  receiptTime   String?   @map("receipt_time")
  paymentMethod String?   @map("payment_method")
  cardLast4     String?   @map("card_last_4")
  itemCount     Int?      @map("item_count")
  subtotalCents Int?      @map("subtotal_cents")
  otherFeesCents Int?     @map("other_fees_cents")
  taxCents      Int?      @map("tax_cents")
  tipCents      Int?      @map("tip_cents")
  payerId       String    @map("payer_id")
  creatorId     String    @map("creator_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastEditedAt  DateTime  @updatedAt @map("last_edited_at")
  deletedAt     DateTime? @map("deleted_at")

  payer      User            @relation("BillPayer", fields: [payerId], references: [id], onDelete: Restrict)
  creator    User            @relation("BillCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  shares     BillShare[]
  lineItems  BillLineItem[]
  activities ActivityEvent[]

  @@index([payerId])
  @@index([creatorId])
  @@index([deletedAt])
  @@index([source])
  @@map("bills")
}

model BillShare {
  id         String    @id @default(uuid())
  billId     String    @map("bill_id")
  userId     String    @map("user_id")
  shareCents Int       @map("share_cents")
  settledAt  DateTime? @map("settled_at")
  settlementStatus BillShareSettlementStatus @default(NOT_PAID) @map("settlement_status")

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([billId, userId])
  @@index([userId])
  @@map("bill_shares")
}

enum BillShareSettlementStatus {
  NOT_PAID
  PENDING
  PAID
}

model BillLineItem {
  id              String   @id @default(uuid())
  billId          String   @map("bill_id")
  name            String
  quantity        Decimal  @default(1) @db.Decimal(10, 3)
  unitPriceCents  Int      @map("unit_price_cents")
  totalPriceCents Int      @map("total_price_cents")
  sortOrder       Int      @map("sort_order")

  bill        Bill                     @relation(fields: [billId], references: [id], onDelete: Cascade)
  assignments BillLineItemAssignment[]

  @@index([billId])
  @@map("bill_line_items")
}

model BillLineItemAssignment {
  id         String @id @default(uuid())
  lineItemId String @map("line_item_id")
  userId     String @map("user_id")

  lineItem BillLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([lineItemId, userId])
  @@index([lineItemId])
  @@index([userId])
  @@map("bill_line_item_assignments")
}

model ActivityEvent {
  id                 String   @id @default(uuid())
  type               String
  message            String
  actorId            String   @map("actor_id")
  billId             String?  @map("bill_id")
  friendInvitationId String?  @map("friend_invitation_id")
  createdAt          DateTime @default(now()) @map("created_at")

  actor            User                @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  bill             Bill?               @relation(fields: [billId], references: [id], onDelete: Cascade)
  friendInvitation FriendInvitation?   @relation(fields: [friendInvitationId], references: [id], onDelete: Cascade)
  recipients       ActivityRecipient[]

  @@index([actorId])
  @@index([createdAt])
  @@map("activity_events")
}

model ActivityRecipient {
  eventId String @map("event_id")
  userId  String @map("user_id")

  event ActivityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
  @@map("activity_recipients")
}
